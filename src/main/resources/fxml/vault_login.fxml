<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.vplayer.ui.controllers.VaultLoginController"
      alignment="CENTER" spacing="20" styleClass="vault-login-container">

    <VBox alignment="CENTER" spacing="10">
        <FontIcon iconLiteral="fas-lock" iconSize="64" styleClass="vault-lock-icon"/>
        <Label fx:id="lblStatus" text="Private Vault Locked" styleClass="vault-status-label"/>
        <Label fx:id="lblInstruction" text="Enter your PIN to unlock" styleClass="vault-instruction-label"/>
    </VBox>

    <HBox alignment="CENTER" spacing="10">
        <PasswordField fx:id="txtPin" promptText="Enter PIN" prefWidth="200" styleClass="pin-field"/>
        <Button fx:id="btnUnlock" text="Unlock" onAction="#handleUnlock" styleClass="unlock-button"/>
    </HBox>

    <Label fx:id="lblError" text="" styleClass="error-label" visible="false"/>

</VBox>
